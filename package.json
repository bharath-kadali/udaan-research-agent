{
  "name": "udaan-research-agent",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint && pnpm lint:python",
    "lint:python": "ruff check services packages/contracts/python && ruff format --check services packages/contracts/python",
    "format:python": "ruff format services packages/contracts/python",
    "test": "turbo run test",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.14.0"
  }
}
