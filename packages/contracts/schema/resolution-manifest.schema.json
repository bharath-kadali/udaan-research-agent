{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udaan.dev/schema/resolution-manifest.json",
  "title": "ResolutionManifest",
  "description": "Phase 4 (JIT Full-Text Resolution) output, consumed by Phase 5.",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectId", "resolutionSummary", "manifest"],
  "$defs": {
    "ResolutionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalRequested", "successfullyResolved", "paywalled"],
      "properties": {
        "totalRequested": { "type": "integer", "minimum": 0 },
        "successfullyResolved": { "type": "integer", "minimum": 0 },
        "paywalled": { "type": "integer", "minimum": 0 }
      }
    },
    "MetadataSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": { "title": { "type": "string" } }
    },
    "ResolutionManifestEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["internalId", "doi", "status", "storagePointer", "metadataSnapshot"],
      "properties": {
        "internalId": { "type": "string" },
        "doi": { "type": ["string", "null"] },
        "status": { "$ref": "enums.schema.json#/$defs/ResolutionStatus" },
        "storagePointer": { "type": ["string", "null"] },
        "metadataSnapshot": { "$ref": "#/$defs/MetadataSnapshot" }
      }
    }
  },
  "properties": {
    "projectId": { "type": "string" },
    "resolutionSummary": { "$ref": "#/$defs/ResolutionSummary" },
    "manifest": {
      "type": "array",
      "items": { "$ref": "#/$defs/ResolutionManifestEntry" }
    }
  }
}
