{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udaan.dev/schema/synthesis-graph.json",
  "title": "SynthesisGraph",
  "description": "Phase 6 (Cross-Source Synthesis & Polarity) output, consumed by Phase 7.",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectId", "synthesisGraph"],
  "$defs": {
    "SynthesisClaimRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimId", "doi", "text"],
      "properties": {
        "claimId": { "type": "string" },
        "doi": { "type": ["string", "null"] },
        "text": { "type": "string" }
      }
    },
    "SynthesisCluster": {
      "type": "object",
      "additionalProperties": false,
      "required": ["clusterId", "generatedTopicLabel", "polarity", "claims"],
      "properties": {
        "clusterId": { "type": "string" },
        "generatedTopicLabel": { "type": "string" },
        "polarity": { "$ref": "enums.schema.json#/$defs/ClusterPolarity" },
        "claims": {
          "type": "array",
          "items": { "$ref": "#/$defs/SynthesisClaimRef" }
        }
      }
    }
  },
  "properties": {
    "projectId": { "type": "string" },
    "synthesisGraph": {
      "type": "array",
      "items": { "$ref": "#/$defs/SynthesisCluster" }
    }
  }
}
