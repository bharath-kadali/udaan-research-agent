{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://udaan.dev/schema/compiled-discovery-manifest.json",
  "title": "CompiledDiscoveryManifest",
  "description": "Phase 1 (Query Orchestration) output, consumed by Phase 2.",
  "type": "object",
  "additionalProperties": false,
  "required": ["projectId", "searchContext", "compilations"],
  "$defs": {
    "TemporalBounds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startYear": { "type": "integer" },
        "endYear": { "type": "integer" }
      }
    },
    "SearchContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["originalQuery", "coreConcepts"],
      "properties": {
        "originalQuery": { "type": "string" },
        "temporalBounds": {
          "anyOf": [{ "$ref": "#/$defs/TemporalBounds" }, { "type": "null" }]
        },
        "coreConcepts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Compilations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["booleanStandard"],
      "properties": {
        "booleanStandard": { "type": "string" },
        "openAlexFilter": { "type": ["string", "null"] },
        "semanticScholarPayload": { "type": ["object", "null"] }
      }
    },
    "DiscoveryTelemetry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputTokens": { "type": ["integer", "null"] },
        "classificationStatus": { "type": ["string", "null"] },
        "degradedMode": { "type": ["boolean", "null"] }
      }
    }
  },
  "properties": {
    "projectId": { "type": "string" },
    "searchContext": { "$ref": "#/$defs/SearchContext" },
    "compilations": { "$ref": "#/$defs/Compilations" },
    "telemetry": { "$ref": "#/$defs/DiscoveryTelemetry" }
  }
}
